# ---------------------------------------------------------------------------
# loco-admin configuration
# Copy to `.env` and adjust. The admin app connects to the SAME database your
# Loco application uses so it can manage the background-job queue.
# ---------------------------------------------------------------------------

# Postgres connection string for the Loco app's database (required).
# Matches Loco's `database.uri`, e.g. postgres://loco:loco@localhost:5432/myapp_development
DATABASE_URL=postgres://loco:loco@localhost:5432/loco_app_development

# Name of the Loco Postgres queue table. Loco defaults to `pg_loco_queue`;
# only change this if your app customised it. (optional)
QUEUE_TABLE=pg_loco_queue

# Path to the Loco scheduler.yaml (or a config/*.yaml with a `scheduler:`
# section). Relative paths resolve from the process working directory. (optional)
SCHEDULER_CONFIG_PATH=scheduler.yaml

# Human label shown in the UI for the environment you're pointed at. (optional)
TARGET_LABEL=local development

# ---------------------------------------------------------------------------
# Servers / metrics — the list of Loco servers to fetch health & metrics from.
# Discovery is pluggable (StaticResolver today; k8s / service registry later).
# ---------------------------------------------------------------------------

# StaticResolver, inline JSON. Each entry: name + baseUrl (or url), optional
# tags[] and metricsPath (a Prometheus-style endpoint the server exposes; Loco
# has none by default, so omit it to show health probes only).
# LOCO_SERVERS=[{"name":"web-1","baseUrl":"http://10.0.0.4:5150","tags":["prod"],"metricsPath":"/metrics"}]

# Alternatively, load the same list from a JSON or YAML file (a bare list, or
# `{ servers: [...] }`). Takes effect only when LOCO_SERVERS is unset.
# LOCO_SERVERS_FILE=servers.yaml

# Per-request timeout (ms) when probing each server. (optional, default 4000)
# METRICS_TIMEOUT_MS=4000
