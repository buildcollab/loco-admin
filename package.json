{
  "name": "loco-admin",
  "private": true,
  "type": "module",
  "description": "Admin console for managing Loco (loco-rs) applications — background jobs and scheduler.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "node --experimental-strip-types scripts/seed.ts"
  },
  "dependencies": {
    "@react-router/node": "^8.1.0",
    "@react-router/serve": "^8.1.0",
    "cron-parser": "^5.6.1",
    "cronstrue": "^3.24.0",
    "isbot": "^5.1.44",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@react-router/dev": "^8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
